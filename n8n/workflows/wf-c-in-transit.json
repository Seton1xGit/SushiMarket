    {
      "id": "node-format",
      "name": "Format InTransit",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2180,
        200
      ],
      "parameters": {
        "jsCode": "const cfg = $('Config').first().json;\nconst CONTACT = '905527093464';\nconst block = [\n  `🇹🇷 Sadece siparişinizin durumunu bildiriyorum.`,\n  `   Herhangi bir konuda açıklama gerekirse lütfen`,\n  `   ${CONTACT} numarasına mesaj gönderin.`,\n  '',\n  `🇷🇺 Я просто уведомляю о статусе заказа.`,\n  `   Если Вам необходимо что-то уточнить —`,\n  `   напишите на номер ${CONTACT}.`,\n  '',\n  `🇬🇧 I'm just notifying you of the order status.`,\n  `   If you need to make changes in your order,`,\n  `   please text ${CONTACT}.`\n].join('\\n');\n\nreturn [{\n  json: {\n    order_id: cfg.order_id,\n    client_phone: cfg.client_phone,\n    target_phone: cfg.target_phone,\n    is_redirected: cfg.is_redirected,\n    template: 'order_in_transit_ru',\n    text: block\n  }\n}];"
      }
    },
