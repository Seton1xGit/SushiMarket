    {
      "id": "node-config",
      "name": "Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        480
      ],
      "parameters": {
        "jsCode": "// Единая точка управления режимами WF-C.\n//\n// dry_run=true → не шлём в WhatsApp, только пишем в notification_log.\n// OPERATOR_REDIRECT_PHONE — пока тестируем, ВСЕ клиентские сообщения летят на этот номер.\n// Когда уверены что всё работает — поставить '' или null.\n\nconst DRY_RUN = false;\nconst OPERATOR_REDIRECT_PHONE = '79000430011';\n\nconst trig = $('Receive Status Change').first().json;\nconst clientPhone = String(trig.client_phone || '').replace(/[^0-9]/g, '');\nconst targetPhone = OPERATOR_REDIRECT_PHONE || clientPhone;\n\nreturn [{\n  json: {\n    dry_run: DRY_RUN,\n    order_id: Number(trig.order_id),\n    client_phone: clientPhone,\n    target_phone: targetPhone,\n    is_redirected: !!OPERATOR_REDIRECT_PHONE,\n    client_name: (trig.client_name && String(trig.client_name).trim()) || null,\n    order_type: Number(trig.order_type) || null,\n    to_status: String(trig.to_status || '')\n  }\n}];"
      }
    },
