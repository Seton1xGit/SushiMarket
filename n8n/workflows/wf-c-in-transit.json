    {
      "id": "node-resolve-zone",
      "name": "Resolve Zone",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        380
      ],
      "parameters": {
        "jsCode": "// TBD-2: явного zone_id в публичном API мы не нашли.\n// Пробуем цепочку кандидатов; первый существующий и > 0 берём как zone_id.\n// Если ни один не найден — zone=null, дальше пойдём по skip-ветке.\n//\n// Если в продакшене окажется, что zone берётся из другого места —\n// поменять список candidates.\n\nconst d = $input.first()?.json || {};\nconst candidates = [\n  d?.delivery?.zone_id,\n  d?.delivery?.zone,\n  d?.zone_id,\n  d?.zone,\n  d?.shop?.zone_id,\n  d?.shop?.zone,\n  d?.shop?.id          // эвристика: shop.id как proxy для zone\n];\nconst zone = candidates.find(v => v != null && Number(v) > 0);\n\nconst cfg = $('Config').first().json;\nreturn [{\n  json: {\n    order_id: cfg.order_id,\n    client_phone: cfg.client_phone,\n    zone_id: zone ? Number(zone) : null,\n    zone_source: zone == null ? 'none' :\n      (d?.delivery?.zone_id ? 'delivery.zone_id' :\n       d?.delivery?.zone ? 'delivery.zone' :\n       d?.zone_id ? 'zone_id' :\n       d?.zone ? 'zone' :\n       d?.shop?.zone_id ? 'shop.zone_id' :\n       d?.shop?.zone ? 'shop.zone' : 'shop.id_fallback'),\n    delivery_address: d?.delivery?.address || null,\n    shop_address: d?.shop?.address || null\n  }\n}];"
      }
    },
