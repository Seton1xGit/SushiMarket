    {
      "id": "node-format",
      "name": "Format Welcome",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1520,
        280
      ],
      "parameters": {
        "jsCode": "// Формирует приветственный текст из деталей заказа.\n\nconst cfg = $('Config').first().json;\nconst details = $input.first()?.json || {};\nconst products = Array.isArray(details.products) ? details.products : [];\nconst subtotal = details.subtotal != null ? details.subtotal : null;\nconst paymentDelivery = details.payment_delivery != null ? Number(details.payment_delivery) : 0;\nconst total = subtotal != null ? Number(subtotal) + (paymentDelivery || 0) : null;\nconst delivery = details.delivery?.address || null;\nconst greeting = cfg.client_name ? `Здравствуйте, ${cfg.client_name}!` : 'Здравствуйте!';\n\nconst lines = [];\nlines.push(`${greeting} Ваш заказ #${cfg.order_id} принят.`);\nif (products.length) {\n  lines.push('');\n  lines.push('В составе:');\n  for (const p of products) {\n    const name = p.name || '?';\n    const cnt  = p.count || 1;\n    const ppu  = p.price_per_unit != null ? Number(p.price_per_unit) : 0;\n    lines.push(`• ${name} × ${cnt}${ppu ? ` — ${ppu * cnt}₺` : ''}`);\n  }\n}\nif (total != null) {\n  lines.push('');\n  lines.push(`Сумма: ${total}₺`);\n}\nif (delivery) {\n  lines.push('');\n  lines.push(`Доставим по адресу: ${delivery}`);\n}\nlines.push('');\nlines.push('Спасибо, что выбрали SushiMarket!');\n\nreturn [{\n  json: {\n    order_id: cfg.order_id,\n    client_phone: cfg.client_phone,\n    target_phone: cfg.target_phone,\n    is_redirected: cfg.is_redirected,\n    template: 'order_received_ru',\n    text: lines.join('\\n'),\n    products_count: products.length,\n    total: total\n  }\n}];"
      }
    },
