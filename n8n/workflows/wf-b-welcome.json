    {
      "id": "node-config",
      "name": "Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        420,
        460
      ],
      "parameters": {
        "jsCode": "// Единая точка управления режимами WF-B.\n//\n// dry_run=true → не шлём в WhatsApp реально, только пишем в notification_log.\n// OPERATOR_REDIRECT_PHONE — пока тестируем, ВСЕ клиентские сообщения летят на этот номер,\n// а не на реальный client_phone. Когда всё проверим — поставить '' или null, и сообщения пойдут клиентам как положено.\n\nconst DRY_RUN = true;\nconst OPERATOR_REDIRECT_PHONE = '79000430011';\n\nconst trig = $('Receive Order').first().json;\nconst clientPhone = String(trig.client_phone || '').replace(/[^0-9]/g, '');\nconst targetPhone = OPERATOR_REDIRECT_PHONE || clientPhone;\n\nreturn [{\n  json: {\n    dry_run: DRY_RUN,\n    order_id: Number(trig.order_id),\n    client_phone: clientPhone,\n    target_phone: targetPhone,\n    is_redirected: !!OPERATOR_REDIRECT_PHONE,\n    client_name: (trig.client_name && String(trig.client_name).trim()) || null,\n    order_type: Number(trig.order_type) || null\n  }\n}];"
      }
    },
