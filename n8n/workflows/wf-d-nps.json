    {
      "id": "node-format",
      "name": "Format NPS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        280
      ],
      "parameters": {
        "jsCode": "const cfg = $('Config').first().json;\nconst greeting = cfg.client_name ? `Здравствуйте, ${cfg.client_name}!` : 'Здравствуйте!';\n\nconst lines = [];\nlines.push(greeting);\nlines.push('');\nlines.push('Поделитесь, пожалуйста, впечатлениями: всё ли вам понравилось?');\nlines.push('Любая обратная связь — большая помощь нам!');\nlines.push('');\nlines.push('Спасибо, что выбрали SushiMarket!');\n\nreturn [{\n  json: {\n    order_id: cfg.order_id,\n    client_phone: cfg.client_phone,\n    template: 'feedback_request_ru',\n    text: lines.join('\\n')\n  }\n}];"
      }
    },
