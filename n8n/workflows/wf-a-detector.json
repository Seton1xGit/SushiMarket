      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://office-tr.sushi-market.com/api/app/v5/order/status",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"orders\":[{{ $json.order_id }}]}",
        "options": {
          "timeout": 10000,
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "OvipNoJ83kkncmrA",
          "name": "cred_datafood_public"
        }
      }
    },
    {
      "id": "node-parse-final",
      "name": "Parse Final",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1740,
        540
      ],
      "parameters": {
        "jsCode": "// Парсим ответ /v5/order/status: {status:'success', result:[{id, status}]}.\n// На несуществующий order_id турецкий стенд возвращает HTTP 404 c {error:...}\n// (не 'canceled', как написано в публичной доке). Учитываем это.\n\nconst src = $('Compute Diff').first().json;\nconst orderId = Number(src.order_id);\nconst body = $input.first()?.json || {};\n\nlet final;\nif (body.error) {\n  // 404 / ошибка сервера → считаем заказ отменённым\n  final = 'canceled';\n} else {\n  const result = Array.isArray(body.result) ? body.result : [];\n  const row = result.find(r => Number(r.id) === orderId) || {};\n  final = String(row.status || 'canceled');\n}\n\nreturn [{\n  json: {\n    order_id: orderId,\n    final_status: final,\n    is_completed: final === 'completed',\n    detected_at: new Date().toISOString()\n  }\n}];"
      }
    },
    {
      "id": "node-update-final",
      "name": "Update Final",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1960,
        540
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE order_events SET last_status = $1, last_seen_at = NOW(), completed_at = CASE WHEN $1 = 'completed' AND completed_at IS NULL THEN NOW() ELSE completed_at END WHERE order_id = $2::bigint",
        "options": {
          "queryReplacement": "={{ $json.final_status || '-' }},={{ $json.order_id }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "VCeTigIhYateDNgR",
          "name": "cred_postgres"
        }
      }
    }
