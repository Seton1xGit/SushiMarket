    {
      "id": "node-validate",
      "name": "Validate Listing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        360
      ],
      "parameters": {
        "jsCode": "const input = $input.first()?.json ?? {};\nlet payload = input;\nif (typeof input === 'string') {\n  try { payload = JSON.parse(input); } catch (e) {\n    throw new Error('Listing body is not JSON: ' + String(input).slice(0, 200));\n  }\n}\nif (typeof payload?.data === 'string') {\n  try { payload = JSON.parse(payload.data); } catch (e) {\n    throw new Error('Listing.data is not JSON: ' + String(payload.data).slice(0, 200));\n  }\n}\nconst rows = Array.isArray(payload?.data) ? payload.data : null;\nif (rows === null) {\n  throw new Error('Listing response has no data array. Got keys: ' + Object.keys(payload || {}).join(','));\n}\nfunction stripHtml(s) {\n  if (typeof s !== 'string') return '';\n  return s.replace(/<[^>]*>/g, ' ').replace(/&nbsp;/g, ' ').replace(/\\s+/g, ' ').trim();\n}\nfunction extractName(s) {\n  const stripped = stripHtml(s);\n  // Убираем телефон-подобные последовательности (8+ цифр со знаками-разделителями).\n  const noPhone = stripped.replace(/[\\d+\\-() ]{8,}/g, ' ').replace(/\\s+/g, ' ').trim();\n  return noPhone || null;\n}\nlet skippedBracketed = 0;\nconst orders = rows.map(r => {\n  const cleanName = extractName(r.ClientName);\n  // Системные/тестовые заказы маркируются префиксом в []: [Web-Se], [Test], etc.\n  // Их игнорируем — не пишем в БД, не отправляем сообщения.\n  if (cleanName && /[\\[\\]]/.test(cleanName)) {\n    skippedBracketed += 1;\n    return null;\n  }\n  return {\n    order_id: Number(r.id),\n    client_phone: typeof r.ClientPhone === 'string' ? r.ClientPhone.replace(/[^0-9]/g, '') : null,\n    client_name: cleanName,\n    order_type: typeof r.order_type === 'number' ? r.order_type : null,\n    status_raw: stripHtml(r.Status).slice(0, 100)\n  };\n}).filter(o => o && Number.isFinite(o.order_id));\nif (skippedBracketed > 0) {\n  console.log(`[wf-a] skipped ${skippedBracketed} bracketed-name orders (system/test)`);\n}\nreturn [{ json: { orders, count: orders.length, skipped_bracketed: skippedBracketed, fetched_at: new Date().toISOString() } }];"
      }
    },
    {
      "id": "node-load-known",
      "name": "Load Known",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        860,
        360
      ],
      "alwaysOutputData": true,
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT order_id, last_status, client_phone, client_name, order_type, welcome_sent_at, transit_sent_at, completed_at, feedback_sent_at FROM order_events WHERE last_status NOT IN ('completed','canceled') AND last_seen_at > NOW() - INTERVAL '7 days'",
        "options": {}
      },
