    {
      "id": "node-insert-new",
      "name": "Insert New Order",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1520,
        200
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO order_events(order_id, client_phone, order_type, last_status, last_seen_at) VALUES ($1::bigint, NULLIF($2, '-'), NULLIF($3, 0)::smallint, $4, NOW()) ON CONFLICT (order_id) DO UPDATE SET last_status = EXCLUDED.last_status, last_seen_at = NOW(), client_phone = COALESCE(order_events.client_phone, EXCLUDED.client_phone)",
        "options": {
          "queryReplacement": "={{ $json.order_id }},={{ $json.client_phone || '-' }},={{ Number($json.order_type) || 0 }},={{ $json.status_raw || '-' }}"
        }
      },
      "credentials": {
        "postgres": {
          "id": "VCeTigIhYateDNgR",
          "name": "cred_postgres"
        }
      }
    },
    {
      "id": "node-update-status",
      "name": "Update Status",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        1520,
        360
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE order_events SET last_status = $1, last_seen_at = NOW() WHERE order_id = $2::bigint",
        "options": {
          "queryReplacement": "={{ $json.status_raw || $json.to_status || '-' }},={{ $json.order_id }}"
        }
      },
