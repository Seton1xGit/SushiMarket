# ============================================================================
# SushiMarket TR — WhatsApp Order Notifications
# Шаблон env-файла. Скопируйте в .env и заполните своими значениями.
# Реальный .env коммитить НЕ нужно (см. .gitignore).
# ============================================================================

# ---------------------------------------------------------------------------
# DataFood public API — детали заказа, статусы, время доставки
# Bearer-токен интегратора на турецком стенде. Выдаёт владелец интеграции.
# Используется в WF-B (Welcome) и WF-C (InTransit).
# ---------------------------------------------------------------------------
DATAFOOD_BASE_URL=https://office-tr.sushi-market.com
DATAFOOD_PUBLIC_TOKEN=

# ---------------------------------------------------------------------------
# Admin-API call-center — триггер «новый заказ» (листинг активных)
# Sanctum personal-access-token формата "<id>|<hash>". Берётся из DevTools
# Network вкладки на call-center-tr.sushi-market.com (Bearer в XHR-запросах).
# Origin/Referer обязательны — сервер их валидирует.
# Используется в WF-A (Detector).
# ---------------------------------------------------------------------------
CALLCENTER_BASE_URL=https://sushimarket-tr.datafood.tech
CALLCENTER_ADMIN_TOKEN=
CALLCENTER_ORIGIN=https://call-center-tr.sushi-market.com
CALLCENTER_REFERER=https://call-center-tr.sushi-market.com/

# ---------------------------------------------------------------------------
# Polling & бизнес-логика
# TZ                   — единый часовой пояс для расчёта окон NPS.
# POLL_INTERVAL_S      — интервал WF-A Schedule-trigger в секундах.
# NPS_DELAY_HOURS      — через сколько часов после completed отправлять NPS.
# NPS_CUTOFF_HOUR      — час суток, после которого NPS не отправляется (24h).
# ALERT_THROTTLE_MIN   — анти-флуд для одинаковых алертов в WF-E (минут).
# ---------------------------------------------------------------------------
TZ=Europe/Istanbul
POLL_INTERVAL_S=15
NPS_DELAY_HOURS=2
NPS_CUTOFF_HOUR=22
ALERT_THROTTLE_MIN=30

# ---------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# META_WA_TOKEN          — long-lived bearer от Meta Business.
# META_PHONE_NUMBER_ID   — ID номера-отправителя в WhatsApp Business.
# META_VERIFY_TOKEN      — произвольная строка для webhook-верификации Meta
#                          (нужна только если будем принимать события).
# META_TEMPLATE_*        — slug-имена утверждённых шаблонов сообщений.
# ---------------------------------------------------------------------------
META_WA_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
META_TEMPLATE_RECEIVED=order_received_ru
META_TEMPLATE_TRANSIT=order_in_transit_ru
META_TEMPLATE_FEEDBACK=feedback_request_ru

# Safety gate. true → WhatsApp-отправки мокаются (только запись в БД без
# сетевого вызова к Meta). false → реальная отправка клиентам.
# По умолчанию true. Переключение в false — по явному решению пользователя
# после полной проверки бэка.
META_DRY_RUN=true

# ---------------------------------------------------------------------------
# Telegram — алерты админу из WF-E
# TELEGRAM_BOT_TOKEN     — формат "<bot_id>:<hash>" от @BotFather.
# TELEGRAM_ADMIN_CHAT_ID — ID чата/канала, куда летят ошибки и эскалации.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ---------------------------------------------------------------------------
# Postgres — state storage (order_events, notification_log, alert_throttle).
# Любая Postgres-совместимая БД: Supabase Free / Neon / собственный инстанс.
# Формат DSN: postgresql://user:password@host:5432/dbname
# ---------------------------------------------------------------------------
POSTGRES_DSN=

# ---------------------------------------------------------------------------
# n8n host — информационно (где крутятся workflow). На сами запросы не влияет.
# ---------------------------------------------------------------------------
N8N_BASE_URL=https://n8n.thefreedom.pro

# ---------------------------------------------------------------------------
# Dashboard — мониторинг + WhatsApp bridge (services/dashboard).
# DASHBOARD_USER / DASHBOARD_PASS — basic-auth для UI.
# DASHBOARD_INTERNAL_TOKEN — секрет, которым n8n будет авторизоваться
# при вызове /api/wa/send (передаётся в заголовке X-Internal-Token).
# Сгенерировать можно командой `openssl rand -hex 32`.
# ---------------------------------------------------------------------------
DASHBOARD_USER=
DASHBOARD_PASS=
DASHBOARD_INTERNAL_TOKEN=
